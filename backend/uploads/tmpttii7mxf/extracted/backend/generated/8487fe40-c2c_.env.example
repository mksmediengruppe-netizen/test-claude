# ==================== PostgreSQL ====================
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_secure_password_123
POSTGRES_PORT=5432

# ==================== Redis ====================
REDIS_PASSWORD=redis_secure_password_456
REDIS_PORT=6379

# ==================== Flask ====================
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production
APP_PORT=5000

# ==================== Nginx ====================
NGINX_PORT=80
NGINX_SSL_PORT=443

# ==================== Additional ====================
# CORS settings
CORS_ORIGINS=http://localhost,http://localhost:80

# Session settings
SESSION_TIMEOUT=3600

# Logging
LOG_LEVEL=INFO